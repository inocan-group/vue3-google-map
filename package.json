{
  "name": "vue3-google-map",
  "version": "0.28.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inocan-group/vue3-google-map.git"
  },
  "homepage": "https://vue3-google-map.com",
  "description": "A set of composable components for easy use of Google Maps in your Vue 3 projects.",
  "unpkg": "dist/index.umd.js",
  "jsdelivr": "dist/index.umd.js",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "browser": "./dist/index.umd.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./themes": {
      "import": "./dist/themes/index.mjs",
      "require": "./dist/themes/index.cjs",
      "types": "./dist/types/themes/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/types/index.d.ts"
      ],
      "themes": [
        "dist/types/themes/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "prepare": "pnpm run build",
    "clean": "rimraf dist/**/*",
    "lint": "npx eslint --ext .ts,.vue src playground --fix",
    "lint:check": "npx eslint --ext .ts,.vue src playground",
    "build:umd": "node ./scripts/build-umd.mjs",
    "build": "pnpm clean && vue-tsc --declaration --emitDeclarationOnly --project tsconfig.build.json && vite build && pnpm build:umd",
    "docs": "vitepress dev docs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "test": "jest",
    "test:types": "pnpm run build && tsc --noEmit --project tsconfig.typetest.json",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "fast-deep-equal": "^3.1.3",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@googlemaps/jest-mocks": "^2.22.8",
    "@types/google.maps": "^3.64.0",
    "@types/jest": "^29.5.14",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^6.0.0",
    "@vue/eslint-config-typescript": "^7.0.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "29.7.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-vue": "^7.20.0",
    "expect-type": "^1.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pnpm": "^10.33.2",
    "prettier": "^2.8.8",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.8.3",
    "vite": "^8.0.10",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitepress": "^1.6.4",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "peerDependencies": {
    "vue": "^3"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "packageManager": "pnpm@10.33.2"
}
