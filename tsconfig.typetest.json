{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "composite": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["google.maps", "jest"],
    "paths": {
      "vue3-google-map": ["./dist/types/index.d.ts"],
      "vue3-google-map/*": ["./dist/types/*"]
    }
  },
  "include": ["tests/types/**/*.ts"]
}
