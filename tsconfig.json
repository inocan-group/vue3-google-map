{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "esModuleInterop": true,
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "google.maps",
      "vite/client",
      "jest"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
    },
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "preserve",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    // Required for accurate Jest coverage line numbers. @vue/vue3-jest reads
    // this root config when compiling SFC <script> blocks, and ts-jest merges
    // it for .ts files; without it Istanbul maps coverage to compiled output.
    // Inert for the build (emitDeclarationOnly above). See tests/vue-jest-transformer.js.
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "dev/**/*.ts",
    "dev/**/*.vue",
    "docs/**/*.ts",
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.typetest.json"
    }
  ]
}
